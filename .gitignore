# ─── tbox-finder .gitignore ────────────────────────────────────────────────
# The repository is PUBLIC from day 1 (CLAUDE.md §4). Never commit secrets,
# W&B keys, NCBI credentials, or large data blobs — those live in DVC, the HF
# Hub, or git-LFS (see .gitattributes).

# ── Local-only working docs (CLAUDE.md §1 — laptop-only, never pushed;
#    ADRs + README.md + MEMORY.md are the cross-machine fallback) ──
/PRD.md
/CLAUDE.md
/imp.md
/TODO.md
/dev-manual.md

# ── DVC per-machine config + local caches (CLAUDE.md §5.2 — the remote
#    differs per machine, so .dvc/config is not committed) ──
/.dvc/config
/.dvc/config.local
/.dvc/tmp/
/.dvc/cache/

# ── Immutable raw / external data (fetched by checksummed download rules;
#    not DVC-tracked, never hand-edited — CLAUDE.md §5.2). Keep the empty
#    directory scaffold, ignore everything else. ──
/data/raw/**
!/data/raw/.gitkeep
/data/external/**
!/data/external/.gitkeep
# Carve-out: the small, immutable §7.1 reference assets (covariance models +
# reference FASTAs + class-II blind set) ARE committed here — git-LFS-tracked
# via .gitattributes, staged by workflow/rules/data.smk::stage_reference_assets
# (P0-11a). Large fetched corpora elsewhere under data/external/ stay ignored.
!/data/external/refs/
!/data/external/refs/**
# Carve-out: the P0-13 GTDB-release pin manifest ONLY (the release id, checksums,
# species-rep counts). The ~49 MB sp_clusters crosswalk + on-demand taxonomy/metadata
# stay ignored — re-fetched by workflow/rules/data.smk::pin_gtdb_release (CLAUDE.md §5.2).
!/data/external/gtdb/
!/data/external/gtdb/provenance.json
# Carve-out: the P0-15 NCBI-taxdump pin manifest ONLY (snapshot id + checksums +
# license). The ~75 MB dated taxdmp zip stays ignored — re-fetched + MD5-verified by
# workflow/rules/data.smk::replace_taxid_lineage (CLAUDE.md §5.2).
!/data/external/ncbi_taxonomy/
!/data/external/ncbi_taxonomy/provenance.json
# Carve-out: the P2-00 NCBI flank-sourcing provenance ONLY (source URL + db + terms +
# accessed date + request/accession counts). The fetched flank itself is DVC-tracked
# under data/interim/flank_context/, not here — re-fetched + exact-match-anchored by
# workflow/rules/data.smk::p2_flank_context (CLAUDE.md §5.2/§10.2).
!/data/external/ncbi_flank/
!/data/external/ncbi_flank/provenance.json
# Carve-out: the P1-12 ArchiveII LOFO benchmark provenance ONLY (pinned tarball
# sha256 + per-family/per-fold counts + lofo digest). The ~1.3 MB folds.json +
# extracted .ct files stay ignored — re-fetched + checksum-verified by
# workflow/rules/backbones.smk::archiveii_lofo_prep (CLAUDE.md §5.2).
!/data/external/archiveii_lofo/
!/data/external/archiveii_lofo/provenance.json
# Carve-out: the P0-16 GATE-1 anchor (arm c) deliverables ONLY — the re-derived
# non-Firmicutes leader FASTA (git-LFS), its provenance, and the audit/leakage report.
# The .cache/ (copyrighted Vitreschak .doc supplement + fetched genome FASTAs) stays
# ignored — re-fetched by workflow/rules/data.smk::source_gate1_anchor (CLAUDE.md §5.2).
!/data/external/gate1_anchor/
!/data/external/gate1_anchor/gate1_anchor.fasta
!/data/external/gate1_anchor/provenance.json
!/data/external/gate1_anchor/gate1_anchor_report.json

# Carve-out: the P0-17 additional-non-Actinobacteria-class-II deliverables ONLY — the
# (verified-empty) positive FASTA, its provenance, and the class-II report (which carries
# the ≥2-source negative determination + the CM/DB-derived P2 lead catalogue by reference).
!/data/external/classII_positives/
!/data/external/classII_positives/classII_positives.fasta
!/data/external/classII_positives/provenance.json
!/data/external/classII_positives/classII_report.json

# Carve-out: the P1-13 official-RiNALMo (Zenodo 15043668) provenance manifest ONLY
# (URLs + md5 + license + DOI for the D5-parity diagnostics). The ~2.6 GB *.pt weight
# files themselves stay ignored (globally *.pt below; re-fetchable by the recorded md5).
!/data/external/rinalmo_official/
!/data/external/rinalmo_official/provenance.json

# The P1-13 parity per-shard SUCCESS markers + flock lock files (empty) are run signals,
# not artifacts; the per-family <family>.json fold results ARE committed alongside the report.
/reports/p1/rinalmo_parity_folds/SHARD_OK_*
/reports/p1/rinalmo_parity_folds/.parity_*.lock

# The TBOX_REQUIRE_TRAIN_CUDA test writes a throwaway report here (test_train_smoke.py) and
# does not clean up. Every other file in reports/p2/ is a real measured artifact, so an
# untracked-and-un-ignored scratch report is a landmine: one `git add -A` and an 8-record,
# 1-step run is committed where it reads as a measurement. It is a run signal, not an artifact.
/reports/p2/_smoke_test.json

# P2-05 sizing: the DONE marker + flock lock are run signals (§9.3 keys on absence-on-
# failure); the per-point ws*_bs*_ckpt*.json ARE committed alongside sizing_smoke.json.
/reports/p2/sizing_smoke.DONE
/reports/p2/.sizing_smoke.lock
/reports/p2/sizing_smoke_*.out
/reports/p2/sizing_smoke_*.err

# P2-06 sweep: the per-point <KEY>.OK success markers and the SLURM array logs are run
# signals (§9.3 keys on the marker's ABSENCE for a failed point, and the .err files are
# expected non-empty — trust_remote_code / torchrun / wandb chatter). The 36 per-point
# <KEY>.json reports ARE committed alongside reports/p2/sweep_selection.json: they are the
# evidence the promoted config was selected on, and tests/ml/test_sweep_selection.py
# re-derives the winner from them in CI.
/reports/p2/sweep/*.OK
/reports/p2/sweep/slurm_*.out
/reports/p2/sweep/slurm_*.err

# P2-06 sweep: the per-point <KEY>.OK markers + per-array-task slurm logs are run signals
# (§9.3 keys on absence-on-failure); the per-point reports/p2/sweep/<KEY>.json ARE the
# committed sweep deliverable (like the sizing per-point reports).
/reports/p2/sweep/*.OK
/reports/p2/sweep/slurm_*.out
/reports/p2/sweep/slurm_*.err

# P2-09/P2-10 production retrain (train_production.sbatch): the DONE marker + flock lock are
# run signals (§9.3 keys on absence-on-failure), and the SLURM logs are EXPECTED non-empty on
# success (torchrun rendezvous / trust_remote_code / W&B-offline chatter — do NOT gate on zero
# bytes). Every sibling job (sizing, sweep) already ignores its own; this one did not, so a
# `git add -A` on the cluster checkout would commit them (P2-10d′-e). The committed report
# reports/p2/train_stage1_production.json is the deliverable and is deliberately NOT ignored.
/reports/p2/train_stage1_production.DONE
/reports/p2/.train_production.lock
/reports/p2/train_production_*.out
/reports/p2/train_production_*.err

# ── Snakemake working dir + rule run-logs (never committed) ──
.snakemake/
/logs/

# ── Hydra job logs ──
# The train configs pin `hydra.run.dir: .` so relative in/out paths resolve from the repo
# root; Hydra's job logger then drops `<job_name>.log` (train_stage1.log, stage1_smoke.log)
# right there. Root-anchored so it never hides a log that matters elsewhere.
/*.log

# ── Experiment tracking (W&B run dirs) ──
**/wandb/
**/.wandb/
.wandb_api_key

# ── Secrets / credentials (public repo — must never be committed) ──
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
credentials.json
*_credentials.json
.netrc
secrets.y*ml
.secrets/
*.token

# ── Data-blob guard: heavy binaries never belong in git (use DVC / HF / LFS).
#    NB: *.parquet, *.fa, *.fasta and *.cm are deliberately NOT guarded here —
#    parquet is DVC-managed (or the git-LFS split-assignment table), and small
#    benchmark FASTAs + covariance models are git-LFS-tracked (.gitattributes). ──
*.bam
*.bai
*.sam
*.cram
*.crai
*.bcf
*.vcf.gz
*.h5
*.hdf5
*.npy
*.npz
# Carve-out: the tiny committed P1-01 kernel-smoke DNA token fixture (1 KB, reproducible
# from manifest.json seed) is a test input, not a data blob.
!tests/fixtures/kernel_smoke_dna/dna_tokens.npy
*.pt
*.pth
*.ckpt
*.safetensors
*.pkl
*.pickle
*.sqlite
*.sqlite3
*.db
*.tar
*.tar.gz
*.tgz
*.zip
*.7z
*.bz2
*.xz
*.zst

# ── Python / build / tooling ──
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
.ipynb_checkpoints/
.venv/
venv/
# uv is only the isolated bare-CI test runner (deps are pinned via conda-lock, not uv).
uv.lock

# ── Quarto / LaTeX render intermediates (rendered dev-log PDFs ARE committed) ──
/.quarto/
*.aux

# ── Worktrees (CLAUDE.md §5.0 — live under .claude/worktrees/) ──
/.claude/worktrees/

# ── OS / editor cruft ──
.DS_Store
Thumbs.db
*.swp
*~
.idea/
.vscode/
