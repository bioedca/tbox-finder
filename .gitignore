# в”Ђв”Ђв”Ђ tbox-finder .gitignore в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# The repository is PUBLIC from day 1 (CLAUDE.md В§4). Never commit secrets,
# W&B keys, NCBI credentials, or large data blobs вЂ” those live in DVC, the HF
# Hub, or git-LFS (see .gitattributes).

# в”Ђв”Ђ Local-only working docs (CLAUDE.md В§1 вЂ” laptop-only, never pushed;
#    ADRs + README.md + MEMORY.md are the cross-machine fallback) в”Ђв”Ђ
/PRD.md
/CLAUDE.md
/imp.md
/TODO.md
/dev-manual.md

# в”Ђв”Ђ DVC per-machine config + local caches (CLAUDE.md В§5.2 вЂ” the remote
#    differs per machine, so .dvc/config is not committed) в”Ђв”Ђ
/.dvc/config
/.dvc/config.local
/.dvc/tmp/
/.dvc/cache/

# в”Ђв”Ђ Immutable raw / external data (fetched by checksummed download rules;
#    not DVC-tracked, never hand-edited вЂ” CLAUDE.md В§5.2). Keep the empty
#    directory scaffold, ignore everything else. в”Ђв”Ђ
/data/raw/**
!/data/raw/.gitkeep
/data/external/**
!/data/external/.gitkeep
# Carve-out: the small, immutable В§7.1 reference assets (covariance models +
# reference FASTAs + class-II blind set) ARE committed here вЂ” git-LFS-tracked
# via .gitattributes, staged by workflow/rules/data.smk::stage_reference_assets
# (P0-11a). Large fetched corpora elsewhere under data/external/ stay ignored.
!/data/external/refs/
!/data/external/refs/**

# в”Ђв”Ђ Snakemake working dir + rule run-logs (never committed) в”Ђв”Ђ
.snakemake/
/logs/

# в”Ђв”Ђ Experiment tracking (W&B run dirs) в”Ђв”Ђ
**/wandb/
**/.wandb/
.wandb_api_key

# в”Ђв”Ђ Secrets / credentials (public repo вЂ” must never be committed) в”Ђв”Ђ
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
credentials.json
*_credentials.json
.netrc
secrets.y*ml
.secrets/
*.token

# в”Ђв”Ђ Data-blob guard: heavy binaries never belong in git (use DVC / HF / LFS).
#    NB: *.parquet, *.fa, *.fasta and *.cm are deliberately NOT guarded here вЂ”
#    parquet is DVC-managed (or the git-LFS split-assignment table), and small
#    benchmark FASTAs + covariance models are git-LFS-tracked (.gitattributes). в”Ђв”Ђ
*.bam
*.bai
*.sam
*.cram
*.crai
*.bcf
*.vcf.gz
*.h5
*.hdf5
*.npy
*.npz
*.pt
*.pth
*.ckpt
*.safetensors
*.pkl
*.pickle
*.sqlite
*.sqlite3
*.db
*.tar
*.tar.gz
*.tgz
*.zip
*.7z
*.bz2
*.xz
*.zst

# в”Ђв”Ђ Python / build / tooling в”Ђв”Ђ
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
.ipynb_checkpoints/
.venv/
venv/

# в”Ђв”Ђ Quarto / LaTeX render intermediates (rendered dev-log PDFs ARE committed) в”Ђв”Ђ
/.quarto/
*.aux

# в”Ђв”Ђ Worktrees (CLAUDE.md В§5.0 вЂ” live under .claude/worktrees/) в”Ђв”Ђ
/.claude/worktrees/

# в”Ђв”Ђ OS / editor cruft в”Ђв”Ђ
.DS_Store
Thumbs.db
*.swp
*~
.idea/
.vscode/
